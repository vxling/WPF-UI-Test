<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 字体 -->
    <FontFamily x:Key="SystemDefaultFont">Segoe UI</FontFamily>

    <!-- 浅色主题配色 -->
    <SolidColorBrush x:Key="DataGridHeaderBackground" Color="#E8E8E8"/>
    <SolidColorBrush x:Key="HeaderHoverBg" Color="#E8E8E8"/>
    <SolidColorBrush x:Key="HeaderPressedBg" Color="#DCDCDC"/>
    <SolidColorBrush x:Key="DataGridHeaderForeground" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="DataGridRowBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DataGridRowAlternatingBackground" Color="#F9F9F9"/>
    <SolidColorBrush x:Key="DataGridRowSelectedBackground" Color="#CCE8FF"/>
    <SolidColorBrush x:Key="DataGridRowSelectedForeground" Color="#000000"/>
    <SolidColorBrush x:Key="RowSelectedBorder" Color="#99C8F0"/>
    <SolidColorBrush x:Key="RowHoverBg" Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="RowSelectedBorderBrush" Color="#99C8F0"/>

    <!-- 基础刷子 -->
    <SolidColorBrush x:Key="WindowBackBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="ControlHoverGrayBrush" Color="#FFF3F3F3"/>

    <!-- 文本框样式 -->
    <SolidColorBrush x:Key="TextBoxBackground" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextBoxForeground" Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="TextBoxBorderBrush" Color="#FFCCCCCC"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="#FF0078D4"/>

    <!-- GridView 表头样式：上下无边框，左右分割线，高度与行对齐 -->
    <Style x:Key="Win11GridViewColumnHeaderStyle" TargetType="GridViewColumnHeader">
        <Setter Property="Background" Value="{DynamicResource DataGridHeaderBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource DataGridHeaderForeground}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
        <Setter Property="Padding" Value="6,0"/>
        <Setter Property="FontFamily" Value="{StaticResource SystemDefaultFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewColumnHeader">
                    <Grid>
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <!-- 右侧拖拽调整宽度的 Thumb -->
                        <Thumb x:Name="PART_HeaderGripper"
                               Width="4"
                               HorizontalAlignment="Right"
                               Cursor="SizeWE"
                               Opacity="0"
                               Background="{TemplateBinding BorderBrush}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HeaderHoverBg}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource HeaderPressedBg}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 文本框样式 -->
    <Style x:Key="Win11TextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource TextBoxBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBoxForeground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource TextBoxBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontFamily" Value="{StaticResource SystemDefaultFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource TextBoxFocusBorderBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>