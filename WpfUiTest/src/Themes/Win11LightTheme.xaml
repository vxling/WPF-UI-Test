<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 字体 -->
    <FontFamily x:Key="SystemDefaultFont">Segoe UI</FontFamily>

    <!-- 基础色值 -->
    <Color x:Key="SystemWindowBackColor">#FFFFFFFF</Color>
    <Color x:Key="SystemTextPrimaryColor">#FF1A1A1A</Color>
    <Color x:Key="SystemControlHoverGray">#FFF3F3F3</Color>

    <!-- 刷子 -->
    <SolidColorBrush x:Key="WindowBackBrush" Color="{StaticResource SystemWindowBackColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource SystemTextPrimaryColor}"/>
    <SolidColorBrush x:Key="ControlHoverGrayBrush" Color="{StaticResource SystemControlHoverGray}"/>

    <!-- ===================== GridView 表头扁平化 ===================== -->
    <Style x:Key="Win11GridViewColumnHeaderStyle" TargetType="GridViewColumnHeader">
        <Setter Property="Background" Value="#FFF3F3F3"/>
        <Setter Property="Foreground" Value="#FF1A1A1A"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontFamily" Value="{StaticResource SystemDefaultFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewColumnHeader">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FFE8E8E8"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FFDCDCDC"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>