<Application x:Class="WpfUiTest.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 自定义 Win11 主题（无 Fluent，避免 GridViewColumnHeader 被隐式样式覆盖） -->
                <ResourceDictionary Source="pack://application:,,,/WpfUiTest;component/Themes/Win11DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>