<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon />
    <StartupObject />
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Serilog" Version="3.1.1" />
    <PackageReference Include="Serilog.Sinks.File" Version="5.0.0" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Themes\Win11DarkTheme.xaml" />
    <None Remove="Themes\Win11LightTheme.xaml" />
  </ItemGroup>
  <ItemGroup>
    <Resource Include="Themes\Win11DarkTheme.xaml" />
    <Resource Include="Themes\Win11LightTheme.xaml" />
  </ItemGroup>
</Project>
