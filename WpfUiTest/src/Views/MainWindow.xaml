<Window x:Class="WpfUiTest.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WPF UI Test - SyncRecord List" Height="500" Width="900"
        MinHeight="400" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource DarkWindowBackBrush}">

    <DockPanel Margin="12">
        <!-- Top: label -->
        <TextBlock DockPanel.Dock="Top" Text="SyncRecord ListView 选中效果测试" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"
                   Foreground="{DynamicResource DarkTextPrimaryBrush}"/>

        <!-- ListView -->
        <ListView x:Name="SyncRecordList"
                  Background="Transparent"
                  BorderThickness="0"
                  ItemContainerStyle="{StaticResource Win11FileListItemStyle}"
                  d:ItemsSource="{d:SampleData ItemCount=8}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="时间" Width="150" DisplayMemberBinding="{Binding TimestampDisplay}"/>
                    <GridViewColumn Header="仓库" Width="100" DisplayMemberBinding="{Binding RepoName}"/>
                    <GridViewColumn Header="文件" Width="280" DisplayMemberBinding="{Binding FilePath}"/>
                    <GridViewColumn Header="操作" Width="100" DisplayMemberBinding="{Binding OperationDisplay}"/>
                    <GridViewColumn Header="结果" Width="80" DisplayMemberBinding="{Binding ResultDisplay}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>