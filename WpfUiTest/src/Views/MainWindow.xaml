<Window x:Class="WpfUiTest.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WPF UI Test - SyncRecord List" Height="500" Width="900"
        MinHeight="400" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackBrush}">

    <DockPanel Margin="12">
        <!-- Top bar: label + theme toggle -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="SyncRecord ListView 选中效果测试" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            <Button x:Name="ThemeToggleButton" Content="🌙 切换浅色" Click="ThemeToggle_Click"
                    Margin="20,0,0,0" Padding="12,4" Cursor="Hand"
                    Background="{DynamicResource ControlHoverGrayBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0"/>
        </StackPanel>

        <!-- ListView - 用 DynamicResource 让样式跟随主题切换 -->
        <ListView x:Name="SyncRecordList"
                  Background="Transparent"
                  BorderThickness="0"
                  ItemContainerStyle="{DynamicResource Win11FileListItemStyle}"
                  GridViewColumnHeader.ColumnHeaderStyle="{StaticResource Win11GridViewColumnHeaderStyle}"
                  ItemsSource="{Binding SyncRecords}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="时间" Width="150" DisplayMemberBinding="{Binding TimestampDisplay}"/>
                    <GridViewColumn Header="仓库" Width="100" DisplayMemberBinding="{Binding RepoName}"/>
                    <GridViewColumn Header="文件" Width="280" DisplayMemberBinding="{Binding FilePath}"/>
                    <GridViewColumn Header="操作" Width="100" DisplayMemberBinding="{Binding OperationDisplay}"/>
                    <GridViewColumn Header="结果" Width="80" DisplayMemberBinding="{Binding ResultDisplay}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>